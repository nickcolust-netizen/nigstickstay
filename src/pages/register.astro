---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import './style.css';
---

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <title>สมัครสมาชิก</title>
</head>
<body>

<div class="register-container">
    <h2>สมัครสมาชิก</h2>

    <div id="alert-box" class="alert" style="display: none;"></div>

    <form id="registerForm">
        <div class="form-row">
            <div class="form-group">
                <label for="username">ชื่อผู้ใช้ (Username)</label>
                <input type="text" id="username" required>
            </div>
            <div class="form-group">
                <label for="first_name">ชื่อ</label>
                <input type="text" id="first_name" required>
            </div>
            <div class="form-group">
                <label for="last_name">นามสกุล</label>
                <input type="text" id="last_name" required>
            </div>
        </div>

        <div class="form-group">
            <label for="email">อีเมล</label>
            <input type="email" id="email" required>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="department">แผนกงาน</label>
                <input type="text" id="department" required>
            </div>
            <div class="form-group">
                <label for="phone">เบอร์โทรศัพท์</label>
                <input type="text" id="phone">
            </div>
        </div>

        <div class="form-group">
            <label for="password">รหัสผ่าน</label>
            <input type="password" id="password" required minlength="6">
        </div>

        <div class="form-group">
            <label for="confirm_password">กรอกรหัสผ่านอีกครั้ง</label>
            <input type="password" id="confirm_password" required minlength="6">
        </div>

        <button type="submit" class="btn-submit" id="btnSubmit">ลงทะเบียน</button>
        
        <div style="text-align: center; margin-top: 15px;">
            <a href="/index" class="btn-secondary" style="text-decoration: none; color: #555; font-size: 14px;">
                มีบัญชีผู้ใช้แล้ว? เข้าสู่ระบบที่นี่
            </a>
        </div>
    </form>
</div>

<script>
const SUPABASE_URL = "https://xkefwusrblrzylvtmwte.supabase.co";
const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhrZWZ3dXNyYmxyenlsdnRtd3RlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM2MjU1NjcsImV4cCI6MjA5OTIwMTU2N30.LMb9yfwpHQoZm30z7QwWJSL8eJ68n7qU8DiItlz0QwQ";

const usernameInput = document.getElementById('username');
const passwordInput = document.getElementById('password');
const confirmPasswordInput = document.getElementById('confirm_password');
const alertBox = document.getElementById('alert-box');

// 🛠️ 1. ดักจับตอนพิมพ์ของ Username (ยอมรับแค่ A-Z, a-z, 0-9, _, -)
usernameInput.addEventListener('input', function(e) {
    const invalidChars = /[^a-zA-Z0-9_\-]/g;
    if (invalidChars.test(this.value)) {
        this.value = this.value.replace(invalidChars, ''); // ลบตัวอักษรที่ไม่ใช่ภาษาอังกฤษทิ้งทันที
        showAlert("ชื่อผู้ใช้ (Username) สามารถพิมพ์ได้เฉพาะภาษาอังกฤษ ตัวเลข และเครื่องหมาย _ - เท่านั้น", "danger");
    }
});

// 🛠️ 2. ดักจับตอนพิมพ์ของ Password (ยอมรับอังกฤษ ตัวเลข และสัญลักษณ์สากล)
const passwordRegex = /[^a-zA-Z0-9_@.\-#$!%*?&]/g;
passwordInput.addEventListener('input', function(e) {
    if (passwordRegex.test(this.value)) {
        this.value = this.value.replace(passwordRegex, '');
        showAlert("รหัสผ่าน (Password) สามารถพิมพ์ได้เฉพาะภาษาอังกฤษ ตัวเลข และสัญลักษณ์สากลเท่านั้น", "danger");
    }
});

confirmPasswordInput.addEventListener('input', function(e) {
    if (passwordRegex.test(this.value)) {
        this.value = this.value.replace(passwordRegex, '');
        showAlert("การยืนยันรหัสผ่าน สามารถพิมพ์ได้เฉพาะภาษาอังกฤษ ตัวเลข และสัญลักษณ์สากลเท่านั้น", "danger");
    }
});

// ฟังก์ชันสำหรับแฮชรหัสผ่านด้วย SHA-256
async function hashPassword(string) {
    const utf8 = new TextEncoder().encode(string);
    const hashBuffer = await crypto.subtle.digest('SHA-256', utf8);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(bytes => bytes.toString(16).padStart(2, '0')).join('');
}

document.getElementById('registerForm').addEventListener('submit', async function(e) {
    e.preventDefault(); 
    
    const btnSubmit = document.getElementById('btnSubmit');
    
    const userName = usernameInput.value.trim();
    const firstName = document.getElementById('first_name').value.trim();
    const lastName = document.getElementById('last_name').value.trim();
    const email = document.getElementById('email').value.trim();
    const department = document.getElementById('department').value.trim();
    const phone = document.getElementById('phone').value.trim();
    const password = passwordInput.value;
    const confirmPassword = confirmPasswordInput.value;

    alertBox.style.display = 'none';
    alertBox.className = 'alert';

    // ตรวจสอบรหัสผ่านตรงกันไหม
    if (password !== confirmPassword) {
        showAlert("รหัสผ่านและการยืนยันรหัสผ่านไม่ตรงกัน", "danger");
        return;
    }

    btnSubmit.disabled = true;
    btnSubmit.innerText = "กำลังบันทึกข้อมูล...";

    try {
        const hashedPassword = await hashPassword(password);

        const formData = {
            username: userName, 
            email: email,
            password_hash: hashedPassword, 
            first_name: firstName,
            last_name: lastName,
            department: department,
            phone: phone
        };

        const response = await fetch(`${SUPABASE_URL}/rest/v1/users`, {
            method: 'POST',
            headers: {
                'apikey': SUPABASE_ANON_KEY,
                'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
                'Content-Type': 'application/json',
                'Prefer': 'return=minimal'
            },
            body: JSON.stringify(formData)
        });

        if (response.status === 201) {
            showAlert("สมัครสมาชิกสำเร็จเรียบร้อยแล้ว!", "success");
            document.getElementById('registerForm').reset(); 
        } else {
            showAlert("เกิดข้อผิดพลาด: ชื่อผู้ใช้ หรืออีเมลนี้อาจถูกใช้งานไปแล้ว", "danger");
        }
    } catch (error) {
        showAlert("ไม่สามารถเชื่อมต่อฐานข้อมูลได้", "danger");
        console.error(error);
    } finally {
        btnSubmit.disabled = false;
        btnSubmit.innerText = "ลงทะเบียน";
    }
});

function showAlert(text, type) {
    alertBox.innerText = text;
    alertBox.className = `alert alert-${type}`;
    alertBox.style.display = 'block';
}
</script>

</body>
</html>
