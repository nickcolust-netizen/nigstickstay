---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import './style.css';
---

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <title>เข้าสู่ระบบ</title>
</head>
<body>

<div class="register-container">
    <h2>เข้าสู่ระบบ</h2>

    <div id="alert-box" class="alert" style="display: none;"></div>

    <form id="loginForm">
        <div class="form-group">
            <label for="username">ชื่อผู้ใช้ (Username)</label>
            <input type="text" id="username" required>
        </div>

        <div class="form-group">
            <label for="password">รหัสผ่าน (Password)</label>
            <input type="password" id="password" required>
        </div>

        <button type="submit" class="btn-submit" id="btnSubmit">เข้าสู่ระบบ</button>
        
        <div style="text-align: center; margin-top: 15px;">
            <a href="/register" class="btn-secondary" style="text-decoration: none; color: #555; font-size: 14px;">
                ยังไม่มีบัญชี? สมัครสมาชิกที่นี่
            </a>
        </div>
    </form>
</div>

<script>
const SUPABASE_URL = "https://xkefwusrblrzylvtmwte.supabase.co";
const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhrZWZ3dXNyYmxyenlsdnRtd3RlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM2MjU1NjcsImV4cCI6MjA5OTIwMTU2N30.LMb9yfwpHQoZm30z7QwWJSL8eJ68n7qU8DiItlz0QwQ";

const usernameInput = document.getElementById('username');
const passwordInput = document.getElementById('password');
const alertBox = document.getElementById('alert-box');

// 🛠️ 1. ดักจับตอนพิมพ์ของ Username (ยอมรับแค่ A-Z, a-z, 0-9, _, -)
usernameInput.addEventListener('input', function(e) {
    const invalidChars = /[^a-zA-Z0-9_\-]/g;
    if (invalidChars.test(this.value)) {
        this.value = this.value.replace(invalidChars, ''); // ลบตัวอักษรไทย/สัญลักษณ์แปลกปลอมออกทันที
        showAlert("ชื่อผู้ใช้ (Username) พิมพ์ได้เฉพาะภาษาอังกฤษ ตัวเลข และเครื่องหมาย _ - เท่านั้น", "danger");
    }
});

// 🛠️ 2. ดักจับตอนพิมพ์ของ Password (ยอมรับอังกฤษ ตัวเลข และสัญลักษณ์สากล)
const passwordRegex = /[^a-zA-Z0-9_@.\-#$!%*?&]/g;
passwordInput.addEventListener('input', function(e) {
    if (passwordRegex.test(this.value)) {
        this.value = this.value.replace(passwordRegex, ''); // ลบอักษรที่ไม่ใช่ข้อกำหนดทอนออกทันที
        showAlert("รหัสผ่าน (Password) พิมพ์ได้เฉพาะภาษาอังกฤษ ตัวเลข และสัญลักษณ์สากลเท่านั้น", "danger");
    }
});

// ฟังก์ชันแฮชรหัสผ่าน SHA-256
async function hashPassword(string) {
    const utf8 = new TextEncoder().encode(string);
    const hashBuffer = await crypto.subtle.digest('SHA-256', utf8);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(bytes => bytes.toString(16).padStart(2, '0')).join('');
}

document.getElementById('loginForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    const btnSubmit = document.getElementById('btnSubmit');
    const username = usernameInput.value.trim();
    const password = passwordInput.value;

    alertBox.style.display = 'none';
    alertBox.className = 'alert';

    // ตรวจสอบความถูกต้องอีกรอบตอนกดส่งเผื่อมีข้อมูลหลุดรอดการสแกน (เช่น การก๊อปปี้วาง)
    const usernameCheck = /^[a-zA-Z0-9_\-]+$/;
    if (!usernameCheck.test(username)) {
        showAlert("ชื่อผู้ใช้ (Username) ต้องเป็นภาษาอังกฤษ ตัวเลข หรือเครื่องหมาย _ และ - เท่านั้น", "danger");
        return;
    }

    const passwordCheck = /^[a-zA-Z0-9_@.\-#$!%*?&]+$/; 
    if (!passwordCheck.test(password)) {
        showAlert("รหัสผ่าน (Password) ต้องเป็นภาษาอังกฤษ ตัวเลข หรือสัญลักษณ์สากลเท่านั้น", "danger");
        return;
    }

    btnSubmit.disabled = true;
    btnSubmit.innerText = "กำลังตรวจสอบข้อมูล...";

    try {
        const response = await fetch(`${SUPABASE_URL}/rest/v1/users?username=eq.${encodeURIComponent(username)}`, {
            method: 'GET',
            headers: {
                'apikey': SUPABASE_ANON_KEY,
                'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
                'Content-Type': 'application/json'
            }
        });

        const users = await response.json();

        if (users.length === 0) {
            showAlert("ไม่พบข้อมูลผู้ใช้งานในระบบ", "danger");
            return;
        }

        const user = users[0];

        if (user.is_suspended) {
            showAlert("บัญชีผู้ใช้ของคุณถูกระงับชั่วคราว โปรดติดต่อเจ้าหน้าที่", "danger");
            return;
        }

        const hashedPassword = await hashPassword(password);

        if (user.password_hash === hashedPassword) {
            await fetch(`${SUPABASE_URL}/rest/v1/users?id=eq.${user.id}`, {
                method: 'PATCH',
                headers: {
                    'apikey': SUPABASE_ANON_KEY,
                    'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
                    'Content-Type': 'application/json',
                    'Prefer': 'return=minimal'
                },
                body: JSON.stringify({ login_attempts: 0 })
            });

            showAlert("เข้าสู่ระบบสำเร็จ!", "success");
            // window.location.href = '/dashboard';
        } else {
            const newAttempts = user.login_attempts + 1;

            if (newAttempts >= 3) {
                await fetch(`${SUPABASE_URL}/rest/v1/users?id=eq.${user.id}`, {
                    method: 'PATCH',
                    headers: {
                        'apikey': SUPABASE_ANON_KEY,
                        'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
                        'Content-Type': 'application/json',
                        'Prefer': 'return=minimal'
                    },
                    body: JSON.stringify({ login_attempts: newAttempts, is_suspended: true })
                });

                showAlert("คุณกรอกรหัสผ่านผิดเกิน 3 ครั้ง บัญชีถูกระงับ โปรดติดต่อเจ้าหน้าที่", "danger");
            } else {
                await fetch(`${SUPABASE_URL}/rest/v1/users?id=eq.${user.id}`, {
                    method: 'PATCH',
                    headers: {
                        'apikey': SUPABASE_ANON_KEY,
                        'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
                        'Content-Type': 'application/json',
                        'Prefer': 'return=minimal'
                    },
                    body: JSON.stringify({ login_attempts: newAttempts })
                });

                showAlert(`รหัสผ่านไม่ถูกต้อง (คุณลองผิดไปแล้ว ${newAttempts}/3 ครั้ง)`, "danger");
            }
        }
    } catch (error) {
        showAlert("เกิดข้อผิดพลาดในการเชื่อมต่อระบบ", "danger");
        console.error(error);
    } finally {
        btnSubmit.disabled = false;
        btnSubmit.innerText = "เข้าสู่ระบบ";
    }
});

function showAlert(text, type) {
    alertBox.innerText = text;
    alertBox.style.display = 'block';
    alertBox.className = `alert alert-${type}`;
}
</script>

</body>
</html>
