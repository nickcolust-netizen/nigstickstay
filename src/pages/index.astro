---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import styles from 'style.css';
---

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <title>สมัครสมาชิก</title>
</head>
<body>

<div class="register-container">
    <h2>สมัครสมาชิก</h2>

    <div id="alert-box" class="alert" style="display: none;"></div>

    <form id="registerForm">
        <div class="form-row">
            <div class="form-group">
                <label for="username">ชื่อ</label>
                <input type="text" id="username" required>
            </div>
            <div class="form-group">
                <label for="first_name">ชื่อ</label>
                <input type="text" id="first_name" required>
            </div>
            <div class="form-group">
                <label for="last_name">นามสกุล</label>
                <input type="text" id="last_name" required>
            </div>
        </div>

        <div class="form-group">
            <label for="email">อีเมล</label>
            <input type="email" id="email" required>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="department">แผนกงาน</label>
                <input type="text" id="department" required>
            </div>
            <div class="form-group">
                <label for="phone">เบอร์โทรศัพท์</label>
                <input type="text" id="phone">
            </div>
        </div>

        <div class="form-group">
            <label for="password">รหัสผ่าน</label>
            <input type="password" id="password" required minlength="6">
        </div>

        <div class="form-group">
            <label for="confirm_password">กรอกรหัสผ่านอีกครั้ง</label>
            <input type="password" id="confirm_password" required minlength="6">
        </div>

        <button type="submit" class="btn-submit" id="btnSubmit">ลงทะเบียน</button>
    </form>
</div>

<script>
// ⚠️ ใส่ข้อมูล Supabase ของคุณตรงนี้
const SUPABASE_URL = "https://YOUR_SUPABASE_URL.supabase.co";
const SUPABASE_ANON_KEY = "YOUR_SUPABASE_ANON_KEY";

document.getElementById('registerForm').addEventListener('submit', async function(e) {
    e.preventDefault(); // ป้องกันการรีโหลดหน้าจอ
    
    const alertBox = document.getElementById('alert-box');
    const btnSubmit = document.getElementById('btnSubmit');
    
    // ดึงค่าจากฟอร์ม
    const userName = document.getElementById('username').value.trim();
    const firstName = document.getElementById('first_name').value.trim();
    const lastName = document.getElementById('last_name').value.trim();
    const email = document.getElementById('email').value.trim();
    const department = document.getElementById('department').value.trim();
    const phone = document.getElementById('phone').value.trim();
    const password = document.getElementById('password').value;
    const confirmPassword = document.getElementById('confirm_password').value;

    // ซ่อนการแจ้งเตือนเก่าก่อน
    alertBox.style.display = 'none';
    alertBox.className = 'alert';

    // 1. ตรวจสอบรหัสผ่านตรงกันไหม
    if (password !== confirmPassword) {
        showAlert("รหัสผ่านและการยืนยันรหัสผ่านไม่ตรงกัน", "danger");
        return;
    }

    // เปิดสถานะกำลังโหลด
    btnSubmit.disabled = true;
    btnSubmit.innerText = "กำลังบันทึกข้อมูล...";

    // เตรียมข้อมูลส่งในรูปแบบ JSON (ชื่อคีย์ต้องตรงกับคอลัมน์ใน SQL)
    // หมายเหตุ: ฝั่ง JavaScript แนะนำให้บันทึกแบบ password ตรงๆ หรือแฮชฝั่ง Client ก่อนส่ง
    const formData = {
        email: email,
        password_hash: password, // ในระบบจริงควรต่อยอดทำเรื่อง Auth หรือแฮชรหัสผ่าน
        first_name: firstName,
        last_name: lastName,
        department: department,
        phone: phone
    };

    try {
        // ยิง Fetch API ไปที่ Supabase REST Endpoint
        const response = await fetch(`${SUPABASE_URL}/rest/v1/users`, {
            method: 'POST',
            headers: {
                'apikey': SUPABASE_ANON_KEY,
                'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
                'Content-Type': 'application/json',
                'Prefer': 'return=minimal'
            },
            body: JSON.stringify(formData)
        });

        if (response.status === 201) {
            showAlert("สมัครสมาชิกสำเร็จเรียบร้อยแล้ว!", "success");
            document.getElementById('registerForm').reset(); // ล้างข้อมูลในฟอร์ม
        } else {
            showAlert("เกิดข้อผิดพลาด: อีเมลนี้อาจถูกใช้งานไปแล้ว หรือระบบขัดข้อง", "danger");
        }
    } catch (error) {
        showAlert("ไม่สามารถเชื่อมต่อฐานข้อมูลได้", "danger");
        console.error(error);
    } finally {
        // คืนสถานะปุ่ม
        btnSubmit.disabled = false;
        btnSubmit.innerText = "ลงทะเบียน";
    }
});

// ฟังก์ชันสำหรับควบคุมกล่องข้อความแจ้งเตือน
function showAlert(text, type) {
    const alertBox = document.getElementById('alert-box');
    alertBox.innerText = text;
    alertBox.classList.add(`alert-${type}`);
    alertBox.style.display = 'block';
}
</script>

</body>
</html>
